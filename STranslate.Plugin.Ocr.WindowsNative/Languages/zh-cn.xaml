<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- 引擎状态 -->
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_Status">引擎状态</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_Status_Description">本插件使用 Windows 系统内置的 OCR 引擎（Windows.Media.Ocr），完全离线运行，无需配置任何 API Key。可用语言取决于当前系统提供的 OCR 能力。</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_EngineLanguage_Label">当前引擎语言：</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_EngineNotAvailable">引擎不可用</sys:String>

    <!-- 语言选择 -->
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_Language">OCR 语言</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_Language_Description">选择 OCR 识别语言，默认为自动检测（使用系统用户首选语言）</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_AutoDetect">自动检测</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_Refresh">刷新语言列表</sys:String>

    <!-- 使用次数 -->
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_UseCount">使用次数</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_UseCount_Format1">已使用</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_UseCount_Format2">次</sys:String>

    <!-- 错误消息 -->
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_LanguageNotSupported">系统未安装「{0}」的 OCR 语言包。</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_LanguageNotSupported_Hint">请在插件设置中选择当前系统可用的 OCR 语言。</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_EngineCreationFailed">无法创建 OCR 引擎。</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_EngineCreationFailed_Hint">当前系统 OCR 引擎不可用，请切换识别语言后重试。</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_AutoLanguageFailed">无法自动检测 OCR 语言。</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_AutoLanguageFailed_Hint">请在插件设置中手动选择可用的 OCR 识别语言。</sys:String>
    <sys:String x:Key="STranslate_Plugin_Ocr_WindowsNative_EmptyResult">未在图片中识别到文字。</sys:String>

</ResourceDictionary>
